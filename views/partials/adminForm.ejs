<form action="/become-admin" method="POST" class="auth-form">
  <div class="form-group">
    <label for="adminPasscode">Admin Passcode</label>
    <input 
      type="password" 
      name="adminPasscode" 
      id="adminPasscode" 
      minlength="1" 
      maxlength="50" 
      required
    >
  </div>
  <button type="submit" class="btn-primary">Verify Admin Status</button>
</form>