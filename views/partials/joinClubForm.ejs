<form action="/join-club" method="post" class="auth-form">
    <div class="form-group">
      <label for="passcode">What is the greatest sci-fi film of all time?</label>
      <input 
        type="text" 
        name="passcode" 
        id="passcode" 
        minlength="1" 
        maxlength="50" 
        required
      >
    </div>
    <button type="submit" class="btn-primary">Submit</button>
</form>