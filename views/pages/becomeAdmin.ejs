<%- include('../partials/header') %>
<main class="container">
  <h1>Become Admin</h1>
  <p>Enter the secret administrator passcode to gain deletion privileges.</p>
  <% if (locals.errors) { %>
    <ul class="error-list">
      <% errors.forEach((error) => { %>
        <li><%= error.msg %></li>
      <% }); %>
    </ul>
  <% } %>
  <%- include('../partials/adminForm') %>
  <p>Changed your mind? <a href="/">Back to home</a>.</p>
</main>
<%- include('../partials/footer') %>